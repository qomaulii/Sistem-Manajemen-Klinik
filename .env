#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
# Gunakan 'development' agar pesan error muncul lengkap saat koding
#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------
encryption.key = hex2bin:1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef
CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
# Sesuaikan dengan URL saat kamu menjalankan server (biasanya port 8080)
app.baseURL = 'http://localhost/Sistem-Manajemen-Klinik/public/'
app.forceGlobalSecureRequests = false
security.csrfProtection = none

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
# Pengaturan koneksi ke database klinik kamu
database.default.hostname = localhost
database.default.database = clinic
database.default.username = root
database.default.password = 
database.default.DBDriver = MySQLi
database.default.port = 3306

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------
# Penting untuk fitur login Dokter/Admin
app.sessionDriver = 'CodeIgniter\Session\Handlers\FileHandler'
app.sessionSavePath = 'writable/session'